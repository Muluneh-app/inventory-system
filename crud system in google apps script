    <script>
    function submitData(event) {
        // This stops the form from refreshing the page
        if(event) event.preventDefault();




        const data = {
            name: document.getElementById('name').value,
            quantity: document.getElementById('quantity').value,
            price: document.getElementById('price').value,
        };




        // UI Feedback
        document.getElementById('msg').innerText = "Saving...";
        document.getElementById('msg').className = "text-blue-600 text-sm";
        google.script.run
            .withSuccessHandler((response) => {
                document.getElementById('msg').innerText = response;
                document.getElementById('msg').className = "text-green-600 text-sm";
                // Clear the form
                document.getElementById('form').reset();


                    // refresh list
                    loadData(); // refresh table
            }).registerProduct(data);
    }
window.onload = function () {
  loadData();
};


function loadData() {
  google.script.run
    .withSuccessHandler(function(data) {


      const tbody = document.getElementById("tableBody");
      tbody.innerHTML = "";


      if (!data || data.length <= 1) {
        tbody.innerHTML = "<tr><td colspan='4'>No data found</td></tr>";
        return;
      }


      data.slice(1).forEach(row => {
        tbody.innerHTML += `
          <tr>
            <td>${row[0] || ""}</td>
            <td>${row[1] || ""}</td>
            <td>${row[2] || ""}</td>
            <td>${row[3] || ""}</td>
          </tr>
        `;
      });


    })
    .withFailureHandler(function(error) {
      console.log(error);
      document.getElementById("msg").innerText = "Load error!";
    })
    .getData();
    }


let editRowId = "";


function submitData(event) {


  if (event) event.preventDefault();


  const data = {
    id: editRowId,
    name: document.getElementById('name').value,
    quantity: document.getElementById('quantity').value,
    price: document.getElementById('price').value,
  };


  document.getElementById('msg').innerText = "Saving...";


  // EDIT
  if (editRowId) {


    google.script.run
      .withSuccessHandler(function(response) {


        document.getElementById('msg').innerText = response;


        document.getElementById('form').reset();


        editRowId = "";


        loadData();


      })
      .updateProduct(data);


  }


  // NEW SAVE
  else {


    google.script.run
      .withSuccessHandler(function(response) {


        document.getElementById('msg').innerText = response;


        document.getElementById('form').reset();


        loadData();


      })
      .registerProduct(data);


  }
}




window.onload = function () {
  loadData();
};




function loadData() {


  google.script.run
    .withSuccessHandler(function(data) {


      const tbody = document.getElementById("tableBody");


      tbody.innerHTML = "";


      if (!data || data.length <= 1) {


        tbody.innerHTML =
          "<tr><td colspan='5'>No data found</td></tr>";


        return;
      }


      data.slice(1).forEach(row => {


        tbody.innerHTML += `
          <tr class="border-b">


            <td class="p-2">${row[0]}</td>
            <td class="p-2">${row[1]}</td>
            <td class="p-2">${row[2]}</td>
            <td class="p-2">${row[3]}</td>


            <td class="p-2">
              <div class="flex gap-2">


                <button
                  onclick="editData(
                    '${row[0]}',
                    '${row[1]}',
                    '${row[2]}',
                    '${row[3]}'
                  )"
                  class="bg-blue-500 text-white px-3 py-1 rounded"
                >
                  Edit
                </button>


                <button
                  onclick="deleteData('${row[0]}')"
                  class="bg-red-500 text-white px-3 py-1 rounded"
                >
                  Delete
                </button>


              </div>
            </td>


          </tr>
        `;
      });


    })
    .getData();
}




function editData(id, name, quantity, price) {


  editRowId = id;


  document.getElementById('name').value = name;


  document.getElementById('quantity').value = quantity;


  document.getElementById('price').value = price;


  document.getElementById('msg').innerText =
    "Editing " + id;


}




function deleteData(id) {


  const confirmDelete =
    confirm("Delete this product?");


  if (!confirmDelete) return;


  google.script.run
    .withSuccessHandler(function(response) {


      document.getElementById('msg').innerText =
        response;


      loadData();


    })
    .deleteProduct(id);
}
</script>
</body>

const sheet_ID="15-8rdTCXK0YJznKc3TF_vqCHOS9tBRzdKdRUbYLHzLs";
function getSheet() {
  return SpreadsheetApp.openById(sheet_ID).getSheetByName("data");
 
}


function doGet() {
  return HtmlService
    .createTemplateFromFile('index')
    .evaluate()
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}


function include(filename) {
  return HtmlService
    .createHtmlOutputFromFile(filename)
    .getContent();
}
function generateProductId() {


  const sheet = getSheet();
  const lastRow = sheet.getLastRow();


  if (lastRow < 2) {
    return "PROD-0001";
  }


  const lastId = sheet.getRange(lastRow, 1).getValue();


  const number =
    parseInt(lastId.replace("PROD-", "")) + 1;


  return "PROD-" + String(number).padStart(4, "0");
}


function registerProduct(data) {


  const sheet = getSheet();


  const productId = generateProductId();


  sheet.appendRow([
    productId,
    data.name,
    data.quantity,
    data.price
  ]);


  return "Data saved successfully!";
}


function getData() {
  const sheet = getSheet();
  return sheet.getDataRange().getValues();
}
function deleteProduct(id) {


  const sheet = getSheet();


  const data = sheet.getDataRange().getValues();


  for (let i = 1; i < data.length; i++) {


    if (data[i][0] == id) {


      sheet.deleteRow(i + 1);


      return "Product deleted!";
    }
  }


  return "Product not found!";
}




function updateProduct(data) {


  const sheet = getSheet();


  const values = sheet.getDataRange().getValues();


  for (let i = 1; i < values.length; i++) {


    if (values[i][0] == data.id) {


      sheet.getRange(i + 1, 2).setValue(data.name);


      sheet.getRange(i + 1, 3).setValue(data.quantity);


      sheet.getRange(i + 1, 4).setValue(data.price);


      return "Product updated!";
    }
  }


  return "Update failed!";
}







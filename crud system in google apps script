<body class="bg-slate-500 h-screen flex items-start justify-start p-6">
  <div class="flex flex-col md:flex-row gap-6 items-start">
    <form id="form" class="form-group">
        <input type="text" id="name" placeholder="Item Name" class="form-input">
        <input type="number" id="quantity" placeholder="Quantity" class="form-input">
         <input type="number" id="price" placeholder="Price" class="form-input">
       <button type="button" onclick="submitData(event)" class="btn btn-submit">Submit</button>            
   
    <p id="msg" class="text-center text-sm font-medium text-blue-600"></p>
    </form>
   <!-- RIGHT: DISPLAY CARD (TAILWIND VERSION) -->
<div class="flex-1 bg-white p-5 rounded-xl shadow-lg gap-4">
 <div class="table-header">
  <h2 class="table-title">Product List</h2>
</div>




      <div class="table-wrapper">
  <table class="table">


    <thead class="table-head">
      <tr>
        <th class="table-th">ID</th>
        <th class="table-th">Name</th>
        <th class="table-th">Qty</th>
        <th class="table-th">Price</th>
        <th class="table-th">Actions</th>
      </tr>
    </thead>


    <tbody id="tableBody" class="table-body">
      <tr class="table-tr">
        <td class="table-td">1</td>
        <td class="table-td">Rice</td>
        <td class="table-td">10</td>
        <td class="table-td">$50</td>


        <td class="table-td">
          <div class="table-actions">
            <button class="table-btn-edit">Edit</button>
            <button class="table-btn-delete">Delete</button>
          </div>
        </td>
      </tr>
    </tbody>


  </table>
</div>
</div>

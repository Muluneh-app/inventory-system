      </label>

      <!-- INPUT -->

      ${

        field.type === "file"

        ?

        `

        <input
          type="file"
          id="${field.id}"
          accept="image/*"

          class="
            w-full
            p-3
            rounded-xl
            border
            border-slate-300
            bg-white
            outline-none
            focus:ring-4
            focus:ring-blue-200
            focus:border-blue-500
            transition
          "
        >

        `

        :

        field.type === "select"

        ?

        `

        <select
          id="${field.id}"

          onchange="
            FormValidator.validateField('${field.id}')
          "

          class="
            w-full
            p-3
            rounded-xl
            border
            border-slate-300
            bg-white
            outline-none
            focus:ring-4
            focus:ring-blue-200
            focus:border-blue-500
            transition
          "
        >

          <option value="">
            Select Category
          </option>

          ${field.options.map(option => `
            <option value="${option}">
              ${option}
            </option>
          `).join("")}

        </select>

        `

        :

        `

        <input
          type="${field.type}"
          id="${field.id}"
          placeholder="${field.placeholder}"

          oninput="
            FormValidator.validateField('${field.id}')
          "

          class="
            w-full
            p-3
            rounded-xl
            border
            border-slate-300
            bg-white
            outline-none
            focus:ring-4
            focus:ring-blue-200

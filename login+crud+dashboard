// ================= LOGIN =================

function checkLogin(username, password) {



  const sheet = getUsersSheet();

  const data = sheet.getDataRange().getValues();



  for (let i = 1; i < data.length; i++) {



    if (

      String(data[i][0]).trim() === String(username).trim() &&

      String(data[i][1]).trim() === String(password).trim()

    ) {



      const user = {

        username: data[i][0],

        role: data[i][2]

      };



      setSession(user);



      return { success: true, user };

    }

  }



  return { success: false };

}



// ================= PRODUCT ID =================

function generateProductId() {



  const sheet = getDataSheet();

  const lastRow = sheet.getLastRow();



  if (lastRow < 2) return "PROD-0001";



  const lastId = sheet.getRange(lastRow, 1).getValue();

  const number = parseInt(lastId.replace("PROD-", "")) + 1;



  return "PROD-" + String(number).padStart(4, "0");

}



// ================= CREATE =================

function registerProduct(data) {



  const sheet = getDataSheet();



  const productId = generateProductId();



  let imageUrl = "";



  if (data.image) {

    imageUrl = uploadFileToDrive(data.image);

  }



  sheet.appendRow([

  productId,

  data.name,

  data.category,

  data.quantity,

  data.price,

  imageUrl

]);



  return "Product saved successfully!";

}



// ================= READ =================

function getData() {

  const data= getDataSheet().getDataRange().getValues();
  return data.slice(1);

}



// ================= DELETE =================

function deleteProduct(id) {



  const sheet = getDataSheet();

  const data = sheet.getDataRange().getValues();



  for (let i = 1; i < data.length; i++) {

    if (data[i][0] == id) {

      sheet.deleteRow(i + 1);

      return "Product deleted!";

    }

  }



  return "Product not found!";

}



// ================= UPDATE =================

function updateProduct(data) {



  const sheet = getDataSheet();

  const values = sheet.getDataRange().getValues();



  for (let i = 1; i < values.length; i++) {



    if (values[i][0] == data.id) {



      let imageUrl = values[i][5];



      if (data.image) {

        imageUrl = uploadFileToDrive(data.image);

      }



      sheet.getRange(i + 1, 2).setValue(data.name);

sheet.getRange(i + 1, 3).setValue(data.category);

sheet.getRange(i + 1, 4).setValue(data.quantity);

sheet.getRange(i + 1, 5).setValue(data.price);

sheet.getRange(i + 1, 6).setValue(imageUrl);

      return "Product updated!";

    }

  }



  return "Update failed!";

}



/* =====================================================

   UPLOAD FILE TO GOOGLE DRIVE (PROFESSIONAL VERSION)

===================================================== */



function uploadFileToDrive(file) {



  try {



    // -------------------------------

    // 1. VALIDATION

    // -------------------------------

    if (!file || !file.base64) {

      throw new Error("Invalid file object");

    }



    const folderId = "1DAKkkO-692cVZaQ8UzB6PD-JPXchikta";

    const folder = DriveApp.getFolderById(folderId);



    // -------------------------------

    // 2. EXTRACT BASE64 DATA

    // -------------------------------

    const base64Data = file.base64.includes(",")

      ? file.base64.split(",")[1]

      : file.base64;



    const bytes = Utilities.base64Decode(base64Data);



    // -------------------------------

    // 3. CREATE BLOB

    // -------------------------------

    const blob = Utilities.newBlob(

      bytes,

      file.type || MimeType.PNG,

      file.name || `image_${Date.now()}.png`

    );



    // -------------------------------

    // 4. UPLOAD FILE

    // -------------------------------

    const uploadedFile = folder.createFile(blob);



    // Make publicly viewable

    uploadedFile.setSharing(

      DriveApp.Access.ANYONE_WITH_LINK,

      DriveApp.Permission.VIEW

    );



    const fileId = uploadedFile.getId();



    // -------------------------------

    // 5. RETURN CLEAN URL (UI FRIENDLY)

    // -------------------------------

    const imageUrl = `https://drive.google.com/uc?export=view&id=${fileId}`;



    return imageUrl;



  } catch (error) {



    console.error("File upload failed:", error.message);



    return "";



  }

} 


<script>
function applyFilters() {

  const searchText =
    document.getElementById("searchInput")
      .value
      .toLowerCase();

  const category =
    document.getElementById("categoryFilter")
      .value
      .toLowerCase();

  filteredData = tableData.filter(row => {

    const matchesSearch =
      row.join(" ")
        .toLowerCase()
        .includes(searchText);

    const matchesCategory =
      category === "" ||
      row[2].toString().trim().toLowerCase() === category;

    return matchesSearch && matchesCategory;

  });

  currentPage = 1;

  displayTable();

  updateStats();
}
</script>




Stats.html



<script>

function updateStats() {

  const data = filteredData;

  if (!data || data.length === 0) {

    document.getElementById("totalProducts").innerText = "0";
    document.getElementById("totalQuantity").innerText = "0";
    document.getElementById("totalPrice").innerText = "$0.00";

    const inventoryValueEl =
      document.getElementById("inventoryValue");

    if (inventoryValueEl) {
      inventoryValueEl.innerText = "$0.00";
    }

    return;
  }

  const totalProducts = data.length;

  let totalQuantity = 0;
  let totalPrice = 0;
  let inventoryValue = 0;

  data.forEach(row => {

    const quantity = Number(row[3]) || 0;
    const price = Number(row[4]) || 0;

    totalQuantity += quantity;
    totalPrice += price;
    inventoryValue += quantity * price;

  });

  document.getElementById("totalProducts").innerText =
    totalProducts.toLocaleString();

  document.getElementById("totalQuantity").innerText =
    totalQuantity.toLocaleString();

  document.getElementById("totalPrice").innerText =
    "$" + totalPrice.toFixed(2);

  const inventoryValueEl =
    document.getElementById("inventoryValue");

  if (inventoryValueEl) {

    inventoryValueEl.innerText =
      "$" + inventoryValue.toFixed(2);

  }

}
</script>





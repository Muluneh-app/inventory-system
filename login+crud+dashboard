<script>

/* =====================================================

       DISPLAY TABLE

    ===================================================== */


function displayTable() {

  const start =
    (currentPage - 1) * rowsPerPage;

  const end =
    start + rowsPerPage;

  const pageItems =
    filteredData.slice(start, end);

  renderRows(pageItems);

  updatePagination();

}

    /* =====================================================


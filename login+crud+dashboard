        document.querySelector("#loginPage form").reset();

        Router.navigate("dashboard");

        loadData();

      } else {

        alert("Invalid Login");

      }

    })

    .checkLogin(
      username,
      password
    );

}

function logout() {

  google.script.run

    .withSuccessHandler(() => {

      Router.navigate("login");

    })

    .logoutUser();

}

window.onload = function() {

  google.script.run

    .withSuccessHandler(user => {

      if (user) {

        Router.navigate("dashboard");

        loadData();

      } else {

        Router.navigate("login");

      }

    })

    .getCurrentUser();

};


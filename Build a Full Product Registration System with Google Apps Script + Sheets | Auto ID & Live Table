// =========================================
// doGet()
// Runs automatically when web app opens
// =========================================
function doGet() {

  // Create HTML template from index.html
  return HtmlService

    // Loads index.html file
    .createTemplateFromFile('index')

    // Converts template into final HTML page
    .evaluate()

    // Allows iframe embedding
    // Useful for some integrations
    .setXFrameOptionsMode(
      HtmlService.XFrameOptionsMode.ALLOWALL
    );
}



// =========================================
// include()
// Used to include external HTML files
// Example:
// <?!= include("Styles"); ?>
// =========================================
function include(filename) {

  return HtmlService

    // Load external HTML file
    .createHtmlOutputFromFile(filename)

    // Return file content as text
    .getContent();
}



// =========================================
// generateProductId()
// Creates automatic product IDs
// Example:
// PROD-0001
// PROD-0002
// =========================================
function generateProductId() {

  // Get active sheet
  const sheet = getSheet();

  // Get last row number
  const lastRow = sheet.getLastRow();

  // =========================================
  // FIRST PRODUCT CHECK
  // If sheet only has header row
  // =========================================
  if (lastRow < 2) {

    // Start first product ID
    return "PROD-0001";
  }

  // =========================================
  // GET LAST PRODUCT ID
  // =========================================

  // Get last ID from column 1
  const lastId = sheet.getRange(lastRow, 1).getValue();

  // Example:
  // PROD-0005

  // =========================================
  // EXTRACT NUMBER
  // =========================================

  const number =

    // Remove "PROD-"
    // Convert remaining text into number
    parseInt(lastId.replace("PROD-", ""))

    // Increase by 1
    + 1;

  // =========================================
  // CREATE NEW FORMATTED ID
  // =========================================

  return "PROD-" +

    // Add leading zeros
    // Example:
    // 1 → 0001
    // 25 → 0025
    String(number).padStart(4, "0");
}



// =========================================
// registerProduct(data)
// Saves product data into Google Sheets
// =========================================
function registerProduct(data) {

  // Get active sheet
  const sheet = getSheet();

  // Generate automatic product ID
  const productId = generateProductId();

  // =========================================
  // SAVE DATA INTO SHEET
  // =========================================
  sheet.appendRow([

    // Column A
    productId,

    // Column B
    data.name,

    // Column C
    data.quantity,

    // Column D
    data.price
  ]);

  // Return success message to frontend
  return "Data saved successfully!";
}



// =========================================
// getData()
// Gets all data from Google Sheets
// Used to display products in table
// =========================================
function getData() {

  // Get active sheet
  const sheet = getSheet();

  // =========================================
  // GET ALL SHEET DATA
  // =========================================

  // getDataRange()
  // Selects all used rows and columns

  // getValues()
  // Returns data as 2D array
  return sheet.getDataRange().getValues();
}



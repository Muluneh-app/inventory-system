<!DOCTYPE html>
<html>

<head>

  <!-- Prevents links from opening outside Apps Script -->
  <base target="_top">

  <!-- Includes external Styles.html file -->
  <?!= include("Styles"); ?>

  <!-- Alternative external CSS file (currently disabled) -->

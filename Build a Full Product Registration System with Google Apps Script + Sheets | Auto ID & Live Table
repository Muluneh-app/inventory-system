</head>

<!-- Main page background + full screen height -->
<body class="bg-slate-500 h-screen flex items-start justify-start p-6">

  <!-- Main container -->
  <!-- flex-col = mobile vertical -->
  <!-- md:flex-row = desktop horizontal -->
  <div class="flex flex-col md:flex-row gap-6 items-start">

    <!-- ========================= -->
    <!-- PRODUCT FORM SECTION -->
    <!-- ========================= -->
    <form id="form" class="form-group">

      <!-- Form Title -->
      <h1 class="text-2xl font-bold text-center w-full mt-4 text-black">
        Product Registration form
      </h1>

      <!-- Product Name Input -->
      <input 
        type="text" 
        id="name" 
        placeholder="Item Name" 
        class="form-input"
      >

      <!-- Product Quantity Input -->
      <input 
        type="number" 
        id="quantity" 
        placeholder="Quantity" 
        class="form-input"
      >

      <!-- Product Price Input -->
      <input 
        type="number" 
        id="price" 
        placeholder="Price" 
        class="form-input"
      >

      <!-- Submit Button -->
      <!-- onclick calls submitData() -->
      <!-- event prevents page refresh -->
      <button 
        type="button"
        onclick="submitData(event)"
        class="btn btn-submit"
      >
        Submit
      </button>

      <!-- Message Area -->
      <!-- Used for success/error/loading messages -->
      <p id="msg" class="text-center text-sm font-medium text-blue-600"></p>

    </form>

    <!-- ========================= -->
    <!-- PRODUCT TABLE SECTION -->
    <!-- ========================= -->

    <!-- Right Side Card -->
    <div class="flex-1 bg-white p-5 rounded-xl shadow-lg gap-4">

      <!-- Table Header -->
      <div class="table-header">

        <!-- Table Title -->
        <h2 class="table-title">Product List</h2>

      </div>

      <!-- Table Wrapper -->
      <div class="table-wrapper">

        <!-- Product Table -->
        <table class="table">

          <!-- ========================= -->
          <!-- TABLE HEAD -->
          <!-- ========================= -->
          <thead class="table-head">

            <tr>

              <!-- Product ID Column -->
              <th class="table-th">ID</th>

              <!-- Product Name Column -->
              <th class="table-th">Name</th>

              <!-- Product Quantity Column -->
              <th class="table-th">Qty</th>

              <!-- Product Price Column -->
              <th class="table-th">Price</th>

            </tr>

          </thead>

          <!-- ========================= -->
          <!-- TABLE BODY -->
          <!-- Dynamic Data Loads Here -->
          <!-- ========================= -->
          <tbody id="tableBody" class="table-body">

          </tbody>

        </table>

      </div>

    </div>

  </div>

  <script>

    // =========================================
    // SUBMIT PRODUCT DATA
    // =========================================
    function submitData(event) {

      // Prevent page refresh after button click
      if(event) event.preventDefault();

      // Collect data from inputs
      const data = {

        // Get product name
        name: document.getElementById('name').value,

        // Get quantity
        quantity: document.getElementById('quantity').value,

        // Get price
        price: document.getElementById('price').value,
      };

      // =========================
      // LOADING MESSAGE
      // =========================

      // Show saving text
      document.getElementById('msg').innerText = "Saving...";

      // Change message color
      document.getElementById('msg').className = "text-blue-600 text-sm";

      // =========================================
      // SEND DATA TO GOOGLE APPS SCRIPT SERVER
      // =========================================
      google.script.run

        // Runs when server succeeds
        .withSuccessHandler((response) => {

          // Show success message
          document.getElementById('msg').innerText = response;

          // Change text color to green
          document.getElementById('msg').className = "text-green-600 text-sm";

          // Reset form fields
          document.getElementById('form').reset();

          // Reload table data automatically
          loadData();

        })

        // Apps Script backend function
        .registerProduct(data);
    }

    // =========================================
    // PAGE LOAD EVENT
    // Runs automatically when page opens
    // =========================================
    window.onload = function () {

      // Load table data immediately
      loadData();
    };

    // =========================================
    // LOAD DATA FROM GOOGLE SHEETS
    // =========================================
    function loadData() {

      // Call Apps Script function
      google.script.run

        // Runs when data loads successfully
        .withSuccessHandler(function(data) {

          // Get table body
          const tbody = document.getElementById("tableBody");

          // Clear old rows
          tbody.innerHTML = "";

          // =========================
          // CHECK IF DATA EXISTS
          // =========================
          if (!data || data.length <= 1) {

            // Show empty message
            tbody.innerHTML = `
              <tr>
                <td colspan='4'>No data found</td>
              </tr>
            `;

            return;
          }

          // =========================================
          // LOOP THROUGH SHEET DATA
          // =========================================

          // Skip header row using slice(1)
          data.slice(1).forEach(row => {

            // Add rows dynamically
            tbody.innerHTML += `
              <tr>

                <!-- Product ID -->
                <td>${row[0] || ""}</td>

                <!-- Product Name -->
                <td>${row[1] || ""}</td>

                <!-- Product Quantity -->
                <td>${row[2] || ""}</td>

                <!-- Product Price -->
                <td>${row[3] || ""}</td>

              </tr>
            `;
          });

        })

        // =========================
        // ERROR HANDLER
        // =========================
        .withFailureHandler(function(error) {

          // Show error in console
          console.log(error);

          // Show user error message
          document.getElementById("msg").innerText = "Load error!";
        })

        // Apps Script backend function
        .getData();
    }

  </script>

</body>
</html>



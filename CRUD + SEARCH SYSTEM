<!DOCTYPE html>
<html>
<head>
  <base target="_top">

  <!-- Tailwind CSS -->
  <?!= include("Styles"); ?> 
   <!-- <link href="Styles.css" rel="stylesheet"> -->
  <title>Inventory CRUD System</title>
</head>

<body class="bg-slate-200 min-h-screen p-6">

  <!-- MAIN CONTAINER -->
  <div class="max-w-7xl mx-auto">

    <!-- PAGE TITLE -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-slate-800">
        Inventory Management System Prepared by Apps Script Academy
      </h1>

      <p class="text-slate-500 mt-2">
        Google Apps Script + Tailwind CSS CRUD App
      </p>
    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- LEFT: FORM CARD -->
      <div class="bg-white rounded-3xl shadow-xl p-6 h-fit">

        <div class="mb-6">
          <h2 class="text-2xl font-bold text-slate-800">
            Product Form
          </h2>

          <p class="text-slate-500 text-sm mt-1">
            Add or update inventory products
          </p>
        </div>

        <!-- FORM -->
        <form id="form" class="space-y-5">

          <!-- PRODUCT NAME -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2">
              Product Name
            </label>

            <input
              type="text"
              id="name"
              placeholder="Enter product name"
              class="
                w-full
                p-3
                rounded-xl
                border
                border-slate-300
                outline-none
                transition
                duration-300
                focus:ring-4
                focus:ring-blue-200
                focus:border-blue-500
              "
            >
          </div>

          <!-- QUANTITY -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2">
              Quantity
            </label>

            <input
              type="number"
              id="quantity"
              placeholder="Enter quantity"
              class="
                w-full
                p-3
                rounded-xl
                border
                border-slate-300
                outline-none
                transition
                duration-300
                focus:ring-4
                focus:ring-blue-200
                focus:border-blue-500
              "
            >
          </div>

          <!-- PRICE -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2">
              Price
            </label>

            <input
              type="number"
              id="price"
              placeholder="Enter price"
              class="
                w-full
                p-3
                rounded-xl
                border
                border-slate-300
                outline-none
                transition
                duration-300
                focus:ring-4
                focus:ring-blue-200
                focus:border-blue-500
              "
            >
          </div>

          <!-- BUTTON -->
          <button
            type="button"
            onclick="submitData(event)"
            class="
              w-full
              bg-blue-600
              hover:bg-blue-700
              text-white
              font-semibold
              py-3
              rounded-xl
              shadow-lg
              transition
              duration-300
              hover:scale-[1.02]
              active:scale-[0.98]
            "
          >
            Save Product
          </button>

          <!-- MESSAGE -->
          <p
            id="msg"
            class="text-center text-sm font-medium"
          ></p>

        </form>

      </div>

      <!-- RIGHT: TABLE CARD -->
      <div class="lg:col-span-2 bg-white rounded-3xl shadow-xl p-6 overflow-hidden">

        <!-- HEADER -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">

          <div>
            <h2 class="text-2xl font-bold text-slate-800">
              Product List
            </h2>

            <p class="text-slate-500 text-sm mt-1">
              Manage all products from here
            </p>
          </div>

        </div>

        <!-- SEARCH -->
        <div class="relative mb-6">

          <!-- ICON -->
          <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">

            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-slate-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z"
              />
            </svg>

          </div>

          <!-- INPUT -->
          <input
            type="text"
            id="searchInput"
            placeholder="Search products..."
            onkeyup="searchTable()"
            class="
              w-full
              pl-12
              pr-4
              py-3
              rounded-2xl
              border
              border-slate-300
              bg-slate-50
              outline-none
              transition-all
              duration-300
              focus:ring-4
              focus:ring-blue-200
              focus:border-blue-500
            "
          >

        </div>

        <!-- TABLE -->
        <div class="overflow-x-auto rounded-2xl border border-slate-200">

          <table class="w-full text-sm">

            <!-- TABLE HEAD -->
            <thead class="bg-slate-800 text-white">

              <tr>

                <th class="p-4 text-left">ID</th>
                <th class="p-4 text-left">Name</th>
                <th class="p-4 text-left">Qty</th>
                <th class="p-4 text-left">Price</th>
                <th class="p-4 text-left">Actions</th>

              </tr>

            </thead>

            <!-- TABLE BODY -->
            <tbody
              id="tableBody"
              class="divide-y divide-slate-200 bg-white"
            >

              <!-- Dynamic Data -->

            </tbody>

          </table>

        </div>

      </div>

    </div>

  </div>

  <script>

    let editRowId = "";

    // PAGE LOAD
    window.onload = function () {
      loadData();
    };

    // SUBMIT DATA
    function submitData(event) {

      if (event) event.preventDefault();

      const data = {
        id: editRowId,
        name: document.getElementById("name").value,
        quantity: document.getElementById("quantity").value,
        price: document.getElementById("price").value,
      };

      document.getElementById("msg").innerText = "Saving...";
      document.getElementById("msg").className =
        "text-blue-600 text-sm text-center";

      // UPDATE
      if (editRowId) {

        google.script.run
          .withSuccessHandler(function (response) {

            document.getElementById("msg").innerText = response;

            document.getElementById("msg").className =
              "text-green-600 text-sm text-center";

            document.getElementById("form").reset();

            editRowId = "";

            loadData();

          })
          .updateProduct(data);

      }

      // NEW SAVE
      else {

        google.script.run
          .withSuccessHandler(function (response) {

            document.getElementById("msg").innerText = response;

            document.getElementById("msg").className =
              "text-green-600 text-sm text-center";

            document.getElementById("form").reset();

            loadData();

          })
          .registerProduct(data);

      }

    }

    // LOAD DATA
    function loadData() {

      google.script.run
        .withSuccessHandler(function (data) {

          const tbody =
            document.getElementById("tableBody");

          tbody.innerHTML = "";

          if (!data || data.length <= 1) {

            tbody.innerHTML = `
              <tr>
                <td colspan="5"
                  class="text-center p-6 text-slate-500">
                  No products found
                </td>
              </tr>
            `;

            return;

          }

          data.slice(1).forEach(row => {

            tbody.innerHTML += `

              <tr class="hover:bg-slate-50 transition">

                <td class="p-4 font-medium">
                  ${row[0]}
                </td>

                <td class="p-4">
                  ${row[1]}
                </td>

                <td class="p-4">
                  ${row[2]}
                </td>

                <td class="p-4 font-semibold text-green-600">
                  $${row[3]}
                </td>

                <td class="p-4">

                  <div class="flex gap-2">

                    <!-- EDIT -->
                    <button
                      onclick="editData(
                        '${row[0]}',
                        '${row[1]}',
                        '${row[2]}',
                        '${row[3]}'
                      )"
                      class="
                        bg-blue-500
                        hover:bg-blue-600
                        text-white
                        px-4
                        py-2
                        rounded-lg
                        transition
                      "
                    >
                      Edit
                    </button>

                    <!-- DELETE -->
                    <button
                      onclick="deleteData('${row[0]}')"
                      class="
                        bg-red-500
                        hover:bg-red-600
                        text-white
                        px-4
                        py-2
                        rounded-lg
                        transition
                      "
                    >
                      Delete
                    </button>

                  </div>

                </td>

              </tr>

            `;

          });

        })
        .withFailureHandler(function (error) {

          console.log(error);

          document.getElementById("msg").innerText =
            "Load error!";

        })
        .getData();

    }

    // EDIT
    function editData(id, name, quantity, price) {

      editRowId = id;

      document.getElementById("name").value = name;

      document.getElementById("quantity").value = quantity;

      document.getElementById("price").value = price;

      document.getElementById("msg").innerText =
        "Editing Product ID: " + id;

    }

    // DELETE
    function deleteData(id) {

      const confirmDelete =
        confirm("Delete this product?");

      if (!confirmDelete) return;

      google.script.run
        .withSuccessHandler(function (response) {

          document.getElementById("msg").innerText =
            response;

          loadData();

        })
        .deleteProduct(id);

    }

    // SEARCH
    function searchTable() {

      const input =
        document.getElementById("searchInput");

      const filter =
        input.value.toLowerCase();

      const rows =
        document.querySelectorAll("#tableBody tr");

      rows.forEach(row => {

        const text =
          row.innerText.toLowerCase();

        if (text.includes(filter)) {

          row.style.display = "";

        } else {

          row.style.display = "none";

        }

      });

    }

  </script>

</body>
</html>     




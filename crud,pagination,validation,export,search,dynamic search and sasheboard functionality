<script>
/* =====================================================
   VALIDATOR
===================================================== */

const FormValidator = {

  validateField(fieldId) {

    const input =
      document.getElementById(fieldId);

    const error =
      document.getElementById(fieldId + "-error");

    const value =
      input.value.trim();

    let message = "";

    /* =========================
       PRODUCT NAME
    ========================= */

    if (fieldId === "name") {

      if (!value) {

        message =
          "Product name required";

      }

      else if (value.length < 3) {

        message =
          "Minimum 3 characters required";

      }

    }

    /* =========================
       QUANTITY
    ========================= */

    if (fieldId === "quantity") {

      if (
        !value
        ||
        isNaN(value)
        ||
        Number(value) <= 0
      ) {

        message =
          "Quantity must be greater than 0";

      }

    }

    /* =========================
       PRICE
    ========================= */

    if (fieldId === "price") {

      if (
        !value
        ||
        isNaN(value)
        ||
        Number(value) <= 0
      ) {

        message =
          "Price must be greater than 0";

      }

    }

    /* =========================
       SHOW ERROR
    ========================= */

    if (message) {

      error.innerText =
        message;

      input.classList.add(
        "border-red-500"
      );

      input.classList.remove(
        "border-green-500"
      );

      return false;

    }

    /* =========================
       SUCCESS
    ========================= */

    error.innerText = "";

    input.classList.remove(
      "border-red-500"
    );

    input.classList.add(
      "border-green-500"
    );

    return true;

  },

  validateForm() {

    const fields = [
      "name",
      "quantity",
      "price"
    ];

    let isValid = true;

    fields.forEach(field => {

      const valid =
        this.validateField(field);

      if (!valid) {

        isValid = false;

      }

    });

    return isValid;

  }

};
</script>


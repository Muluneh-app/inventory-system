<script>

/* =====================================================
   GLOBAL VARIABLES
===================================================== */

let editRowId = "";

let currentPage = 1;

const rowsPerPage = 5;

let tableData = [];

/* =====================================================
   FORM CONFIG
===================================================== */

const formFields = [

  {
    label: "Product Name",
    type: "text",
    id: "name",
    placeholder: "Enter product name"
  },

  {
    label: "Quantity",
    type: "number",
    id: "quantity",
    placeholder: "Enter quantity"
  },

  {
    label: "Price",
    type: "number",
    id: "price",
    placeholder: "Enter price"
  }

];


/* =====================================================
   CREATE FIELD
===================================================== */

function createField(field) {

  return `

    <div>

      <label
        class="
          block
          text-sm
          font-semibold
          text-slate-700
          mb-2
        "
      >
        ${field.label}
      </label>

      <input
        type="${field.type}"
        id="${field.id}"
        placeholder="${field.placeholder}"

        oninput="
          FormValidator.validateField('${field.id}')
        "

        class="
          w-full
          p-3
          rounded-xl
          border
          border-slate-300
          outline-none
          focus:ring-4
          focus:ring-blue-200
          focus:border-blue-500
          transition
        "
      >

      <p
        id="${field.id}-error"
        class="
          text-red-600
          text-sm
          mt-1
        "
      ></p>

    </div>

  `;

}

/* =====================================================
   RENDER FORM
===================================================== */

function renderForm() {

  const form =
    document.getElementById("form");

  form.innerHTML =

    formFields.map(field =>
      createField(field)
    ).join("")

    +

    `

    <button
      type="submit"
      class="
        w-full
        bg-blue-600
        hover:bg-blue-700
        text-white
        font-semibold
        py-3
        rounded-xl
        shadow-lg
        transition
      "
    >
      Save Product
    </button>

    <p
      id="msg"
      class="
        text-center
        text-sm
        font-medium
      "
    ></p>

  `;

}

/* =====================================================
   SUBMIT DATA
===================================================== */

function submitData(event) {

  event.preventDefault();

  /* =========================
     VALIDATE FORM
  ========================= */

  if (!FormValidator.validateForm()) {

    document.getElementById("msg").innerText =
      "Please fix validation errors";

    document.getElementById("msg").className =
      "text-red-600 text-sm text-center";

    return;

  }

  /* =========================
     FORM DATA
  ========================= */

  const data = {

    id: editRowId,

    name:
      document.getElementById("name").value,

    quantity:
      document.getElementById("quantity").value,

    price:
      document.getElementById("price").value

  };

  /* =========================
     LOADING MESSAGE
  ========================= */

  document.getElementById("msg").innerText =
    "Saving...";

  document.getElementById("msg").className =
    "text-blue-600 text-sm text-center";

  /* =========================
     UPDATE
  ========================= */

  if (editRowId) {

    google.script.run

      .withSuccessHandler(function(response) {

        document.getElementById("msg").innerText =
          response;

        document.getElementById("msg").className =
          "text-green-600 text-sm text-center";

        document.getElementById("form").reset();

        editRowId = "";

        loadData();

      })

      .withFailureHandler(function(error) {

        document.getElementById("msg").innerText =
          error.message;

      })

      .updateProduct(data);

  }

  /* =========================
     SAVE
  ========================= */

  else {

    google.script.run

      .withSuccessHandler(function(response) {

        document.getElementById("msg").innerText =
          response;

        document.getElementById("msg").className =
          "text-green-600 text-sm text-center";

        document.getElementById("form").reset();

        loadData();

      })

      .withFailureHandler(function(error) {

        document.getElementById("msg").innerText =
          error.message;

      })

      .registerProduct(data);

  }

}

/* =====================================================
   LOAD DATA
===================================================== */

function loadData() {

  google.script.run

    .withSuccessHandler(function(data) {

      if (!data || data.length <= 1) {

        renderRows([]);

        return;

      }

      tableData = data.slice(1);

      currentPage = 1;

      updateStats();

      displayTable();

    })

    .getData();

}

/* =====================================================
   PAGE LOAD
===================================================== */

window.onload = function() {

  renderForm();

  loadData();

};

</script>


  function exportExcel() {

    google.script.run
      .withSuccessHandler((data) => {

        const headers = data[0];

        const rows = data.slice(1);

        const exportData = rows.map(row => ({
          ID: row[0],
          Name: row[1],
          Quantity: row[2],
          Price: row[3]
        }));

        const worksheet =
          XLSX.utils.json_to_sheet(exportData);

        const workbook =
          XLSX.utils.book_new();

        XLSX.utils.book_append_sheet(
          workbook,
          worksheet,
          "Products"
        );

        XLSX.writeFile(
          workbook,
          "Inventory_Data.xlsx"
        );

      })
      .getData();
  }

  // =========================================
  // EXPORT PDF
  // =========================================
  function exportPDF() {

    google.script.run
      .withSuccessHandler((data) => {

        const rows = data.slice(1);

        const body = rows.map(row => ([
          row[0],
          row[1],
          row[2],
          "$" + row[3]
        ]));

        const { jsPDF } = window.jspdf;

        const doc = new jsPDF();

        // TITLE
        doc.setFontSize(18);

        doc.text(
          "Inventory Management Report",
          14,
          20
        );

        // DATE
        doc.setFontSize(10);

        doc.text(
          "Generated: " + new Date().toLocaleString(),
          14,
          28
        );

        // TABLE
        doc.autoTable({
          startY: 35,

          head: [[
            "ID",
            "Name",
            "Quantity",
            "Price"
          ]],

          body: body,

          theme: "grid",

          headStyles: {
            fillColor: [30, 41, 59]
          },

          styles: {
            fontSize: 10,
            cellPadding: 3
          }
        });

        doc.save("Inventory_Report.pdf");

      })
      .getData();
  }

</script>



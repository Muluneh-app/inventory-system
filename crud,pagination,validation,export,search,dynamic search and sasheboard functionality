    function updateStats() {

      const totalProducts =
        tableData.length;

      let totalQuantity = 0;

      let totalPrice = 0;

      tableData.forEach(row => {

        totalQuantity +=
          Number(row[2]) || 0;

        totalPrice +=
          Number(row[3]) || 0;

      });

      document.getElementById("totalProducts").innerText =
        totalProducts;

